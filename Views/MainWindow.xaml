<Window x:Class="ProcareDownloader.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ProcareDownloader.ViewModels"
        xmlns:conv="clr-namespace:ProcareDownloader.Converters"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Procare Photo Downloader"
        Icon="/Assets/AppIcon.ico"
        Width="1100" Height="760"
        MinWidth="860" MinHeight="620"
        Background="#F7F9FC"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:StateToVisibilityConverter x:Key="LoginVis" TargetState="Login"/>
        <conv:StateToVisibilityConverter x:Key="StudentVis" TargetState="SelectStudent"/>
        <conv:StateToVisibilityConverter x:Key="GalleryVis" TargetState="Gallery"/>
        <conv:MultiStateVisibilityConverter x:Key="GalleryOrDownloadVis" States="Gallery,Downloading,Done"/>
        <conv:MultiStateVisibilityConverter x:Key="LoadingVis" States="LoadingStudents,LoadingPhotos"/>
        <conv:MultiStateVisibilityConverter x:Key="DownloadingVis" States="Downloading"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <conv:BoolToVisibilityConverter x:Key="InvBoolVis" Invert="True"/>
        <conv:SelectedBorderConverter x:Key="SelBorder"/>

        <Style x:Key="SettingsListBox" TargetType="ListBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#0F172A"/>
            <Setter Property="Padding" Value="0"/>
        </Style>

        <Style x:Key="SettingsListBoxItem" TargetType="ListBoxItem">
            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Root"
                                Background="#FFFFFF"
                                BorderBrush="#E2E8F0"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,10">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#0D9488"/>
                                <Setter TargetName="Root" Property="Background" Value="#ECFDF5"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="BorderBrush" Value="#0D9488"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#FFFFFF" BorderThickness="0,0,0,1" BorderBrush="#E2E8F0">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="32" Height="32" Background="#0D9488" CornerRadius="8" Margin="0,0,12,0">
                        <TextBlock Text="📷" FontSize="17" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Procare" Foreground="#0F172A" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    <TextBlock Text=" Photo Downloader" Foreground="#64748B" FontSize="16" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Settings"
                            Style="{StaticResource GhostButton}"
                            Margin="0,0,8,0"
                            Command="{Binding OpenSettingsCommand}"/>
                    <Button Content="← Change Student"
                            Style="{StaticResource GhostButton}"
                            Visibility="{Binding State, Converter={StaticResource GalleryOrDownloadVis}}"
                            Command="{Binding BackToStudentsCommand}"
                            IsEnabled="{Binding State, Converter={StaticResource GalleryVis}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid Visibility="{Binding State, Converter={StaticResource LoginVis}}">
                <wv2:WebView2 x:Name="LoginWebView"/>
                <Border Background="#F7F9FC" Opacity="0.4"
                        Visibility="{Binding IsIndeterminate, Converter={StaticResource BoolVis}}"/>
            </Grid>

            <StackPanel Visibility="{Binding State, Converter={StaticResource LoadingVis}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="220" Height="4"
                             Foreground="#0D9488" Background="#E2E8F0" BorderThickness="0"/>
                <TextBlock Text="{Binding StatusMessage}" Foreground="#64748B"
                           FontSize="14" Margin="0,16,0,0" HorizontalAlignment="Center"/>
            </StackPanel>

            <StackPanel Visibility="{Binding State, Converter={StaticResource StudentVis}}"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Width="420">
                <TextBlock Text="Select a Student" Foreground="#0F172A" FontSize="24"
                           FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Choose whose photos you'd like to download."
                           Foreground="#64748B" FontSize="13" HorizontalAlignment="Center"
                           Margin="0,0,0,14"/>
                <TextBlock Text="{Binding SubStatus}" Foreground="#94A3B8" FontSize="12"
                           HorizontalAlignment="Center" Margin="0,0,0,24"/>
                <ItemsControl ItemsSource="{Binding Students}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Margin="0,6" Padding="20,16"
                                    Background="#FFFFFF" BorderThickness="1"
                                    BorderBrush="#E2E8F0" Cursor="Hand"
                                    Command="{Binding DataContext.SelectStudentCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                    CommandParameter="{Binding}">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="42" Height="42" CornerRadius="21"
                                                        Background="#E2E8F0" Margin="0,0,14,0">
                                                    <Grid ClipToBounds="True">
                                                        <Image Source="{Binding PhotoUrl}"
                                                               Stretch="UniformToFill"
                                                               Visibility="{Binding HasPhotoUrl, Converter={StaticResource BoolVis}}"/>
                                                        <TextBlock Text="👤" FontSize="20"
                                                                   Visibility="{Binding HasNoPhotoUrl, Converter={StaticResource BoolVis}}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FullName}" Foreground="#0F172A"
                                                               FontSize="15" FontWeight="SemiBold"/>
                                                    <TextBlock Text="Tap to view photos"
                                                               Foreground="#64748B" FontSize="12"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#F0FDFA"/>
                                                <Setter Property="BorderBrush" Value="#0D9488"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>

            <Grid Visibility="{Binding State, Converter={StaticResource GalleryOrDownloadVis}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#FFFFFF" Padding="16,10"
                        BorderThickness="0,0,0,1" BorderBrush="#E2E8F0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="{Binding SelectedStudent.FullName}" Foreground="#0F172A"
                                       FontSize="15" FontWeight="Bold"/>
                            <TextBlock Foreground="#64748B" FontSize="13" Margin="10,0,0,0">
                                <TextBlock.Text>
                                    <MultiBinding StringFormat="{}{0} photos · {1} selected · {2} saved">
                                        <Binding Path="TotalCount"/>
                                        <Binding Path="SelectedCount"/>
                                        <Binding Path="DownloadedCount"/>
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Style="{StaticResource GhostButton}"
                                Command="{Binding ToggleSelectAllCommand}"
                                IsEnabled="{Binding State, Converter={StaticResource GalleryVis}}"
                                Content="{Binding SelectAllButtonText}"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#F7F9FC" Padding="12">
                    <ItemsControl x:Name="PhotoGrid" ItemsSource="{Binding GalleryRows}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:DesktopGalleryRowViewModel}">
                                <Grid Margin="0,0,0,10">
                                    <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                                            CornerRadius="8" Padding="12,10"
                                            Visibility="{Binding IsHeader, Converter={StaticResource BoolVis}}">
                                        <Grid MinHeight="42">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.InputBindings>
                                                <MouseBinding MouseAction="LeftClick" Command="{Binding ToggleExpandedCommand}"/>
                                            </Grid.InputBindings>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Label}" FontSize="16" FontWeight="Bold" Foreground="#0F172A"/>
                                                <TextBlock Foreground="#64748B" FontSize="12" Margin="10,2,0,0">
                                                    <TextBlock.Text>
                                                        <MultiBinding StringFormat="{}{0} photos · {1} selected · {2} saved">
                                                            <Binding Path="TotalCount"/>
                                                            <Binding Path="SelectedCount"/>
                                                            <Binding Path="DownloadedCount"/>
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource GhostButton}"
                                                    Margin="12,0,0,0"
                                                    Command="{Binding ToggleMonthSelectionCommand}"
                                                    Content="{Binding ToggleLabel}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding ChevronGlyph}" Foreground="#0D9488"
                                                       FontSize="22" VerticalAlignment="Center" Margin="10,0,0,0"/>
                                        </Grid>
                                    </Border>

                                    <ItemsControl ItemsSource="{Binding Photos}"
                                                  Visibility="{Binding IsPhotoRow, Converter={StaticResource BoolVis}}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="{x:Type vm:PhotoViewModel}">
                                                <Border Width="156" Height="156" Margin="0,0,8,0"
                                                        CornerRadius="6" Cursor="Hand"
                                                        BorderThickness="2"
                                                        BorderBrush="{Binding IsSelected, Converter={StaticResource SelBorder}}"
                                                        Background="#FFFFFF"
                                                        MouseLeftButtonUp="Photo_Click">
                                                    <Grid ClipToBounds="True">
                                                        <Image Source="{Binding Thumbnail}"
                                                               Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>

                                                        <Border Background="#FFFFFF"
                                                                Visibility="{Binding IsLoaded, Converter={StaticResource InvBoolVis}}">
                                                            <TextBlock Text="Loading" FontSize="12"
                                                                       Foreground="#64748B"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>

                                                        <Border VerticalAlignment="Bottom"
                                                                Background="#EFFFFFFF"
                                                                Padding="6,4">
                                                            <TextBlock Text="{Binding DateLabel}" Foreground="#64748B" FontSize="10"/>
                                                        </Border>

                                                        <Border Width="24" Height="24" CornerRadius="12"
                                                                Background="#0D9488"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                Margin="0,6,6,0"
                                                                Visibility="{Binding IsSelected, Converter={StaticResource BoolVis}}">
                                                            <TextBlock Text="✓" Foreground="#F7F9FC"
                                                                       FontWeight="Bold" FontSize="13"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                        </Border>

                                                        <Border HorizontalAlignment="Left"
                                                                VerticalAlignment="Top"
                                                                Margin="6"
                                                                Background="#E616A34A"
                                                                CornerRadius="4"
                                                                Padding="6,2"
                                                                Visibility="{Binding IsDownloaded, Converter={StaticResource BoolVis}}">
                                                            <TextBlock Text="Saved" Foreground="#F7F9FC"
                                                                       FontWeight="Bold" FontSize="10"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="2" Background="#FFFFFF" Padding="16,12"
                        BorderThickness="0,1,0,0" BorderBrush="#E2E8F0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <ProgressBar Value="{Binding ProgressValue}" Maximum="100"
                                         Height="6" Foreground="#0D9488" Background="#E2E8F0"
                                         BorderThickness="0" Margin="0,0,16,6"
                                         Visibility="{Binding State, Converter={StaticResource DownloadingVis}}"/>
                            <TextBlock Text="{Binding ProgressText}" Foreground="#0F172A" FontSize="11"
                                       Visibility="{Binding State, Converter={StaticResource DownloadingVis}}"
                                       Margin="0,0,0,2"/>
                            <TextBlock Text="{Binding SubStatus}" Foreground="#64748B" FontSize="11"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <Button Grid.Column="1" Content="Cancel"
                                Style="{StaticResource GhostButton}"
                                Margin="0,0,8,0"
                                Command="{Binding CancelOperationCommand}"
                                Visibility="{Binding State, Converter={StaticResource DownloadingVis}}"/>

                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="Open Folder"
                                    Style="{StaticResource GhostButton}"
                                    Margin="0,0,8,0"
                                    IsEnabled="{Binding HasLastSavedFolder}"
                                    Click="OpenLastSavedFolderBtn_Click"/>
                            <Button Content="{Binding UnsavedDownloadButtonText}"
                                    AutomationProperties.Name="Download Unsaved Photos"
                                    Style="{StaticResource GhostButton}"
                                    Margin="0,0,8,0"
                                    x:Name="DownloadUnsavedBtn"
                                    IsEnabled="{Binding State, Converter={StaticResource GalleryVis}}"
                                    Click="DownloadUnsavedBtn_Click"/>
                            <Button Content="⬇ Download Selected"
                                    Style="{StaticResource TealButton}"
                                    x:Name="DownloadBtn"
                                    IsEnabled="{Binding State, Converter={StaticResource GalleryVis}}"
                                    Click="DownloadBtn_Click"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#FFFFFF" Padding="16,6"
                BorderThickness="0,1,0,0" BorderBrush="#E2E8F0">
            <TextBlock Text="{Binding StatusMessage}" Foreground="#64748B" FontSize="11"/>
        </Border>

        <Grid Grid.RowSpan="3" Panel.ZIndex="10"
              Background="#660F172A"
              Visibility="{Binding IsSettingsOpen, Converter={StaticResource BoolVis}}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="380"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="1" Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1,0,0,0">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="Settings" Foreground="#0F172A" FontSize="20" FontWeight="Bold"/>
                            <TextBlock Text="Save layout, account session, and download tracking." Foreground="#64748B" FontSize="12" Margin="0,4,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Close" Style="{StaticResource GhostButton}"
                                Command="{Binding CloseSettingsCommand}"/>
                    </Grid>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="8" Padding="14" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Save Layout" Foreground="#0F172A" FontSize="15" FontWeight="Bold"/>
                                    <TextBlock Text="Choose the folder structure used when you download selected photos." Foreground="#64748B" FontSize="12" Margin="0,4,0,12"/>
                                    <TextBlock Foreground="#64748B" FontSize="12" Margin="0,0,0,12">
                                        <Run Text="Preview: "/>
                                        <Run Text="{Binding DownloadLayoutPreview, Mode=OneWay}" Foreground="#0F172A"/>
                                    </TextBlock>
                                    <ListBox ItemsSource="{Binding DownloadLayoutOptions}"
                                             SelectedItem="{Binding SelectedDownloadLayout}"
                                             Style="{StaticResource SettingsListBox}"
                                             ItemContainerStyle="{StaticResource SettingsListBoxItem}">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Label}" Foreground="#0F172A" FontWeight="SemiBold" FontSize="13"/>
                                                    <TextBlock Text="{Binding Description}" Foreground="#64748B" FontSize="11" TextWrapping="Wrap" Margin="0,4,0,0"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </Border>

                            <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="8" Padding="14" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Download Tracking" Foreground="#0F172A" FontSize="15" FontWeight="Bold"/>
                                    <TextBlock Foreground="#64748B" FontSize="12" Margin="0,6,0,0">
                                        <Run Text="Tracked downloads: "/>
                                        <Run Text="{Binding DownloadHistoryCount, Mode=OneWay}" Foreground="#0F172A"/>
                                    </TextBlock>
                                    <TextBlock Foreground="#64748B" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap">
                                        Photos you already saved are marked with a `Saved` badge in the gallery and will be skipped on future downloads.
                                    </TextBlock>
                                    <Button Content="Import Existing Downloads Folder"
                                            Style="{StaticResource GhostButton}"
                                            Margin="0,12,0,0"
                                            Click="ImportDownloadsBtn_Click"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="8" Padding="14" Margin="0,0,0,14">
                                <StackPanel>
                                    <TextBlock Text="Photo Cache" Foreground="#0F172A" FontSize="15" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CacheUsageText}" Foreground="#64748B" FontSize="12" Margin="0,6,0,0"/>
                                    <Button Content="Clear Photo Cache"
                                            Style="{StaticResource GhostButton}"
                                            Margin="0,12,0,0"
                                            Command="{Binding ClearCacheCommand}"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                                    CornerRadius="8" Padding="14">
                                <StackPanel>
                                    <TextBlock Text="Account" Foreground="#0F172A" FontSize="15" FontWeight="Bold"/>
                                    <TextBlock Text="Clear the current Procare session and sign in with a different account." Foreground="#64748B" FontSize="12" Margin="0,4,0,12" TextWrapping="Wrap"/>
                                    <Button Content="Log Out And Change Account"
                                            Style="{StaticResource TealButton}"
                                            Click="LogoutBtn_Click"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <TextBlock Grid.Row="2" Text="Settings are saved automatically." Foreground="#94A3B8" FontSize="11" Margin="0,14,0,0"/>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.RowSpan="3" Panel.ZIndex="20"
              Background="#CC0F172A"
              Visibility="{Binding IsPhotoViewerOpen, Converter={StaticResource BoolVis}}">
            <Border Background="#FFFFFF" BorderBrush="#E2E8F0" BorderThickness="1"
                    CornerRadius="8" Padding="14" Margin="42">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding PhotoViewerTitle}" Foreground="#0F172A" FontSize="18" FontWeight="Bold"/>
                            <TextBlock Text="{Binding PhotoViewerSubtitle}" Foreground="#64748B" FontSize="12" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Button Grid.Column="1" Content="Close" Style="{StaticResource GhostButton}"
                                Command="{Binding ClosePhotoViewerCommand}"/>
                    </Grid>

                    <Grid Grid.Row="1" Background="#F7F9FC">
                        <Image Source="{Binding PhotoViewerImage}" Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <ProgressBar Width="180" Height="4" IsIndeterminate="True"
                                     Foreground="#0D9488" Background="#E2E8F0"
                                     BorderThickness="0"
                                     Visibility="{Binding IsPhotoViewerLoading, Converter={StaticResource BoolVis}}"/>
                    </Grid>

                    <Grid Grid.Row="2" Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Previous" Style="{StaticResource GhostButton}"
                                Command="{Binding ShowPreviousPhotoCommand}"
                                IsEnabled="{Binding CanShowPreviousPhoto}"
                                Margin="0,0,8,0"/>
                        <Button Grid.Column="1" Content="Next" Style="{StaticResource TealButton}"
                                Command="{Binding ShowNextPhotoCommand}"
                                IsEnabled="{Binding CanShowNextPhoto}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
